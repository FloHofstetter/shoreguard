# ShoreGuard environment configuration
# Copy to .env and adjust values before running docker compose up

# ── Required ��─────────────────────────────────��──────────────────────────
POSTGRES_PASSWORD=changeme          # PostgreSQL password (CHANGE THIS)
SHOREGUARD_SECRET_KEY=changeme      # HMAC secret for session cookies (CHANGE THIS)

# ── Optional ��───────────���────────────────────────────────────────────────
# SHOREGUARD_ADMIN_PASSWORD=         # Bootstrap admin account (skip setup wizard)
# SHOREGUARD_LOG_LEVEL=info          # debug | info | warning | error
# SHOREGUARD_PORT=8888               # Host port mapping
# SHOREGUARD_ALLOW_REGISTRATION=false # Allow self-registration for new users

# ── Production (docker-compose.prod.yml) ─────────────────────────────
# SHOREGUARD_DOMAIN=shoreguard.example.com  # Domain for Caddy auto-TLS
# SHOREGUARD_VERSION=latest                 # Image tag (e.g. 0.16.0)
