# ShoreGuard Stack Configuration
# Copy to .env and edit as needed: cp .env.example .env

# --- ShoreGuard ---
SHOREGUARD_SECRET_KEY=change-me-to-a-random-64-char-hex-string
SHOREGUARD_ADMIN_PASSWORD=admin
SHOREGUARD_DB_PASSWORD=shoreguard
# HTTPS port for ShoreGuard UI (via Caddy)
SHOREGUARD_PORT=443

# --- Paperclip ---
BETTER_AUTH_SECRET=change-me-to-another-random-hex-string
PAPERCLIP_DB_PASSWORD=paperclip
PAPERCLIP_PORT=3100
PAPERCLIP_PUBLIC_URL=http://localhost:3100

# --- OpenClaw ---
OPENCLAW_GATEWAY_TOKEN=change-me-to-a-random-token
OPENCLAW_GATEWAY_PORT=18789
OPENCLAW_BRIDGE_PORT=18790
OPENCLAW_TZ=Europe/Berlin
